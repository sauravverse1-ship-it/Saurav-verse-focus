rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['uid', 'xp', 'level', 'totalFocusTime', 'pomodorosCompleted']) &&
        request.resource.data.xp == 0;
      allow update: if isOwner(userId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['xp', 'level', 'streak', 'lastActiveDate', 'totalFocusTime', 'pomodorosCompleted', 'settings', 'displayName', 'photoURL']);

      match /tasks/{taskId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(taskId);
        allow update, delete: if isOwner(userId);
      }

      match /sessions/{sessionId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(sessionId);
      }

      match /habits/{habitId} {
        allow list, get: if isOwner(userId);
        allow create, update, delete: if isOwner(userId) && isValidId(habitId);
      }
    }
  }
}
