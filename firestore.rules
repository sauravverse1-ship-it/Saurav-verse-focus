rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function incoming() { 
      return request.resource.data; 
    }

    function existing() { 
      return resource.data; 
    }

    // --- Validation Blueprints ---
    
    function isValidRoom(data) {
      return data.keys().hasAll(['name', 'isPrivate', 'password', 'mode', 'maxMembers', 'status', 'hostId', 'members', 'messages', 'createdAt', 'timerState', 'timerDuration', 'timerTarget', 'sessionGoal'])
        && data.name is string && data.name.size() <= 100
        && data.isPrivate is bool
        && (data.password == null || data.password is string)
        && data.mode is string
        && data.maxMembers is number
        && data.status is string
        && data.hostId is string
        && data.members is list
        && data.messages is list
        && data.createdAt is timestamp
        && data.timerState is string
        && data.timerDuration is number
        && (data.timerTarget == null || data.timerTarget is number)
        && (data.sessionGoal == null || data.sessionGoal is string)
        && (!data.keys().contains('soundboardTrigger') || data.soundboardTrigger == null || data.soundboardTrigger is map);
    }

    // --- Main Match Blocks ---

    // Rooms Collection
    match /rooms/{roomId} {
      allow read, write: if isSignedIn();
    }

    // Users and their subcollections
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Legacy support for other collections
    match /social/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isOwner(resource.data.userId);
    }

    match /events/{eventId} { allow read: if isSignedIn(); }
    match /store/{itemId} { allow read, write: if isSignedIn(); }
    match /tournaments/{id} { allow read, write: if isSignedIn(); }
    match /broadcasts/{id} { allow read, write: if isSignedIn(); }
  }
}
