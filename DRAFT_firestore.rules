rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidUser(data, userId) {
      return data.keys().hasAll(['uid', 'xp', 'level', 'displayName', 'totalFocusSeconds', 'pomodorosCompleted', 'rank', 'allTimeXP', 'dailyChallenges']) &&
             data.uid == userId &&
             data.xp is int &&
             data.allTimeXP is int &&
             data.level is int &&
             data.displayName is string;
    }

    function isValidTask(data, userId) {
      return data.keys().hasAll(['userId', 'title', 'completed', 'category', 'priority', 'sessions', 'expectedSessions', 'createdAt', 'urgent', 'isRevision', 'subjects']) &&
             data.userId == userId &&
             data.title is string &&
             data.completed is bool &&
             data.category in ['study', 'personal', 'health'] &&
             data.priority in ['high', 'medium', 'low', 'urgent', 'standard'];
    }

    function isValidHabit(data, userId) {
      return data.keys().hasAll(['userId', 'title', 'streak', 'completedDates', 'icon', 'createdAt', 'streakBest']) &&
             data.userId == userId &&
             data.title is string &&
             data.completedDates is list;
    }

    function isValidSession(data, userId) {
      return data.keys().hasAll(['userId', 'duration', 'timestamp', 'xpEarned']) &&
             data.userId == userId &&
             data.duration is int &&
             data.xpEarned is int;
    }

    // --- Main Match Blocks ---

    match /users/{userId} {
      // User Profile
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming(), userId);
      allow update: if isOwner(userId) && isValidUser(incoming(), userId) && (
        // Action: Settings/XP Update
        incoming().diff(existing()).affectedKeys().hasAny(['xp', 'allTimeXP', 'level', 'rank', 'dailyChallenges', 'unlockedAchievements', 'photoURL', 'totalFocusSeconds', 'pomodorosCompleted', 'health', 'skills', 'settings', 'lastActiveDate'])
      );

      // Tasks Collection
      match /tasks/{taskId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(taskId);
        allow create: if isOwner(userId) && isValidTask(incoming(), userId);
        allow update: if isOwner(userId) && isValidTask(incoming(), userId) && (
          // Partial updates must still result in valid task state
          // Action: Toggle completion or edit details
          incoming().diff(existing()).affectedKeys().hasAny(['completed', 'completedAt', 'title', 'priority', 'sessions', 'expectedSessions', 'category', 'subjects', 'urgent'])
        );
        allow delete: if isOwner(userId);
      }

      // Habits Collection
      match /habits/{habitId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(habitId);
        allow create: if isOwner(userId) && isValidHabit(incoming(), userId);
        allow update: if isOwner(userId) && isValidHabit(incoming(), userId) && (
          // Action: Mark complete or update streak
          incoming().diff(existing()).affectedKeys().hasAny(['completedDates', 'streak', 'streakBest', 'title', 'icon'])
        );
        allow delete: if isOwner(userId);
      }

      // Sessions Collection
      match /sessions/{sessionId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(sessionId);
        allow create: if isOwner(userId) && isValidSession(incoming(), userId);
        // Sessions are Records - Immutable after creation
        allow update, delete: if false;
      }
    }
  }
}
